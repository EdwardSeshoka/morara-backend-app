{
  "name": "morara-backend-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/main/app/Lambda/index.js",
  "scripts": {
    "clean": "node ./scripts/clean.mjs",
    "build": "npm run clean && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "cdk:deploy:dev": "DEPLOY_ENVIRONMENT=dev npx cdk deploy \"morara-dev/*\" --app \"node dist/infra/cdk/bin/app.js\"",
    "cdk:deploy:beta": "DEPLOY_ENVIRONMENT=beta npx cdk deploy \"morara-beta/*\" --app \"node dist/infra/cdk/bin/app.js\"",
    "cdk:deploy:production": "DEPLOY_ENVIRONMENT=production npx cdk deploy \"morara-production/*\" --app \"node dist/infra/cdk/bin/app.js\"",
    "cdk:destroy:dev": "DEPLOY_ENVIRONMENT=dev npx cdk destroy \"morara-dev/*\" --force --app \"node dist/infra/cdk/bin/app.js\"",
    "cdk:destroy:beta": "DEPLOY_ENVIRONMENT=beta npx cdk destroy \"morara-beta/*\" --force --app \"node dist/infra/cdk/bin/app.js\"",
    "cdk:destroy:production": "DEPLOY_ENVIRONMENT=production npx cdk destroy \"morara-production/*\" --force --app \"node dist/infra/cdk/bin/app.js\""
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.18.0",
    "@aws-sdk/client-dynamodb": "^3.642.0",
    "@aws-sdk/lib-dynamodb": "^3.642.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^25.2.3",
    "aws-cdk": "^2.1106.0",
    "aws-cdk-lib": "^2.179.0",
    "constructs": "^10.3.0",
    "typescript": "^5.6.3"
  }
}
