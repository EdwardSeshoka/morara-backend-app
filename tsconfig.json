{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": [
      "node",
      "aws-lambda"
    ],
    "baseUrl": ".",
    "paths": {
      "@shared/*": [
        "packages/shared/*"
      ]
    }
  },
  "include": [
    "main/**/*.ts",
    "src/**/*.ts",
    "infra/**/*.ts",
    "packages/**/*.ts",
    "scripts/**/*.mjs"
  ]
}
